{
  "kind": "collectionType",
  "collectionName": "pharmacies",
  "info": {
    "singularName": "pharmacy",
    "pluralName": "pharmacies",
    "displayName": "Pharmacy",
    "description": "Farmacias registradas en el sistema"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "clave": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "direccion": {
      "type": "text"
    },
    "contacto_email": {
      "type": "email"
    },
    "min_stock_default": {
      "type": "integer",
      "default": 5
    },
    "estado": {
      "type": "enumeration",
      "default": "activo",
      "enum": [
        "activo",
        "inactivo"
      ]
    },
    "pharmacy_stocks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::pharmacy-stock.pharmacy-stock",
      "mappedBy": "pharmacy"
    },
    "facturas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::factura.factura",
      "mappedBy": "pharmacy"
    },
    "razonSocial": {
      "type": "string"
    },
    "rfc": {
      "type": "string"
    },
    "contacto_tel": {
      "type": "string"
    }
  }
}
