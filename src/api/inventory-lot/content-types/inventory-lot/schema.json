{
  "kind": "collectionType",
  "collectionName": "inventory_lots",
  "info": {
    "singularName": "inventory-lot",
    "pluralName": "inventory-lots",
    "displayName": "inventoryLot"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "inventory_lots"
    },
    "lotNumber": {
      "type": "string"
    },
    "expirationDate": {
      "type": "date"
    },
    "initialQuantity": {
      "type": "integer"
    },
    "currentAmount": {
      "type": "integer"
    },
    "compra": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::compra-pos.compra-pos",
      "inversedBy": "inventory_lots"
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "activo",
        "agotado",
        "vencido"
      ]
    }
  }
}
